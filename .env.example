# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: Frontend Gemini API key used by the Vite app.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Firebase web app configuration for the frontend.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="solarsystem-5a753.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="solarsystem-5a753"
VITE_FIREBASE_STORAGE_BUCKET="solarsystem-5a753.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="729421765241"
VITE_FIREBASE_APP_ID="1:729421765241:web:6b3f4c1fe42fde8a1f52a8"
VITE_FIREBASE_MEASUREMENT_ID="G-7XDK9WK6PV"
VITE_FIREBASE_DATABASE_ID="ai-studio-904e9c90-1065-4897-a0fa-dc2db9f6c91c"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional explicit API base for frontend upload calls.
# Keep empty in production when Hosting rewrites /api/** to backend.
# For local development you can set this to http://localhost:5000
VITE_API_BASE_URL=""
