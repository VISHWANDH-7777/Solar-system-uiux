{
  "entities": {
    "Document": {
      "title": "Document",
      "description": "A legal document and its metadata",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the document" },
        "title": { "type": "string", "description": "Document title" },
        "purpose": { "type": "string", "description": "AI-generated purpose summary" },
        "category": { "type": "string", "description": "Document category" },
        "overall_risk_score": { "type": "number", "description": "Overall risk score (0-100)" },
        "complexity_score": { "type": "number", "description": "Overall complexity score (0-100)" },
        "fairness_index": { "type": "number", "description": "Fairness index (0-100)" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["userId", "title", "created_at"]
    },
    "Clause": {
      "title": "Clause",
      "description": "A specific legal clause within a document",
      "type": "object",
      "properties": {
        "documentId": { "type": "string", "description": "Parent document ID" },
        "clause_title": { "type": "string", "description": "Clause title" },
        "clause_text": { "type": "string", "description": "Original clause text" },
        "simplified_text": { "type": "string", "description": "AI-simplified text" },
        "category": { "type": "string", "description": "Clause category" },
        "importance_score": { "type": "number", "description": "Importance score (0-100)" },
        "risk_level": { "type": "string", "enum": ["Low", "Medium", "High"], "description": "Risk level" },
        "complexity": { "type": "number", "description": "Complexity score (0-100)" },
        "financial_risk": { "type": "number", "description": "Financial risk score (0-100)" },
        "legal_risk": { "type": "number", "description": "Legal risk score (0-100)" },
        "operational_risk": { "type": "number", "description": "Operational risk score (0-100)" }
      },
      "required": ["documentId", "clause_title", "clause_text", "simplified_text"]
    },
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": { "type": "string", "enum": ["dark", "light"] },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User role for access control" },
        "highThinkingEnabled": { "type": "boolean" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Collection of legal documents"
    },
    "/documents/{docId}/clauses/{clauseId}": {
      "schema": "Clause",
      "description": "Sub-collection of clauses for a document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings"
    }
  }
}
